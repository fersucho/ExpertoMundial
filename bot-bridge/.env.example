# URL of the Firebase Cloud Functions (local emulator or deployed endpoint)
# For local emulator: http://127.0.0.1:5001/<your-project-id>/us-central1
FIREBASE_FUNCTIONS_URL=http://127.0.0.1:5001/experto-mundial/us-central1

# A secret token to authorize requests from the bot bridge to Cloud Functions
# This protects your public endpoints from unauthorized requests
BOT_SECRET_TOKEN=my_super_secret_token_12345
